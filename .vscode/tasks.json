{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: 构建项目 (所有文件)",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-fexec-charset=GBK",
                "${workspaceFolder}\\*.cpp",
                "-o",
                "${workspaceFolder}\\build\\PuzzleSolver.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译所有 .cpp 文件到 build 目录"
        },
        {
            "type": "shell",
            "label": "创建 build 目录",
            "command": "if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\"",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "确保 build 目录存在"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: 完整构建 (带清理)",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-fexec-charset=GBK",
                "${workspaceFolder}\\*.cpp",
                "-o",
                "${workspaceFolder}\\build\\PuzzleSolver.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": [
                "创建 build 目录"
            ],
            "group": "build",
            "detail": "先创建目录再编译"
        }
    ],
    "version": "2.0.0"
}